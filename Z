<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NOOB SCRIPT — Premium Script Service</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg:       #07080f;
  --bg2:      #0b0d17;
  --surface:  rgba(255,255,255,0.03);
  --border:   rgba(255,255,255,0.06);
  --border-h: rgba(100,210,255,0.25);
  --accent:   #4af0ff;
  --accent2:  #7b5cff;
  --red:      #ff4466;
  --text:     #e8eaf2;
  --muted:    rgba(232,234,242,0.42);
  --faint:    rgba(232,234,242,0.12);
  --glow-a:   0 0 40px rgba(74,240,255,0.18);
  --glow-b:   0 0 80px rgba(123,92,255,0.14);
  --r:        12px;
}

html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  line-height: 1.6;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── ANIMATED BG ── */
.bg-noise {
  position: fixed; inset: 0; z-index: 1; pointer-events: none;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px;
}

.blob {
  position: fixed; border-radius: 50%; filter: blur(120px); z-index: 0; pointer-events: none;
  animation: drift 18s ease-in-out infinite alternate;
}
.blob-1 {
  width: 680px; height: 680px;
  background: radial-gradient(circle, rgba(74,240,255,0.07) 0%, transparent 70%);
  top: -200px; left: -100px;
}
.blob-2 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(123,92,255,0.09) 0%, transparent 70%);
  bottom: -150px; right: -100px;
  animation-delay: -9s; animation-duration: 22s;
}
.blob-3 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(255,68,102,0.05) 0%, transparent 70%);
  top: 40%; left: 55%;
  animation-delay: -4s; animation-duration: 15s;
}
@keyframes drift {
  from { transform: translate(0, 0) scale(1); }
  to   { transform: translate(40px, 60px) scale(1.1); }
}

.grid-h {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background-image: repeating-linear-gradient(
    0deg,
    rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px,
    transparent 1px, transparent 80px
  );
}

canvas#stars {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
}

/* ── NAVBAR ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 0 48px;
  height: 68px;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(7,8,15,0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
.nav-logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: 0.18em;
  color: var(--accent);
  text-transform: uppercase;
  text-shadow: 0 0 20px rgba(74,240,255,0.5);
}
.nav-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.68rem;
  color: var(--muted);
  letter-spacing: 0.08em;
  padding: 4px 12px;
  border: 1px solid var(--border);
  border-radius: 100px;
}
.nav-status {
  display: flex; align-items: center; gap: 7px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.05em;
}
.pulse-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: #3dff99;
  box-shadow: 0 0 8px #3dff99;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.7)} }

/* ── HERO ── */
.hero {
  position: relative; z-index: 10;
  min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 100px 24px 60px;
  text-align: center;
}

.eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 6px 18px;
  background: rgba(74,240,255,0.06);
  border: 1px solid rgba(74,240,255,0.18);
  border-radius: 100px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 32px;
  opacity: 0;
  animation: rise 0.7s 0.2s cubic-bezier(.22,1,.36,1) forwards;
}
.eyebrow-line { width: 20px; height: 1px; background: var(--accent); opacity: 0.6; }

/* ── BRAND ── */
.brand-block {
  margin-bottom: 20px;
  opacity: 0;
  animation: rise 0.8s 0.35s cubic-bezier(.22,1,.36,1) forwards;
}
.brand {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(3.5rem, 10vw, 8rem);
  letter-spacing: -0.01em;
  line-height: 0.95;
  color: #fff;
  position: relative;
  display: inline-block;
}
.brand .word-noob {
  display: block;
  background: linear-gradient(135deg, #fff 30%, var(--accent) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 30px rgba(74,240,255,0.3));
}
.brand .word-script {
  display: block;
  background: linear-gradient(135deg, var(--accent2) 0%, var(--accent) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 30px rgba(123,92,255,0.4));
}
.brand::before, .brand::after {
  content: attr(data-text);
  position: absolute; inset: 0;
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: inherit; line-height: inherit; letter-spacing: inherit;
  pointer-events: none; white-space: pre;
}
.brand::before {
  background: linear-gradient(135deg, var(--red) 0%, #ff8800 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  opacity: 0; animation: glitch-a 6s infinite;
  clip-path: polygon(0 25%, 100% 25%, 100% 45%, 0 45%);
}
.brand::after {
  background: linear-gradient(135deg, var(--accent) 0%, #fff 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  opacity: 0; animation: glitch-b 6s infinite;
  clip-path: polygon(0 65%, 100% 65%, 100% 80%, 0 80%);
}
@keyframes glitch-a {
  0%,90%,100%{opacity:0;transform:none}
  92%{opacity:0.7;transform:translate(-5px,0)}
  94%{opacity:0;transform:translate(5px,0)}
}
@keyframes glitch-b {
  0%,88%,100%{opacity:0;transform:none}
  89%{opacity:0.6;transform:translate(4px,0)}
  92%{opacity:0;transform:none}
}

/* ── SLOGAN ── */
.slogan {
  font-weight: 300;
  font-size: clamp(0.9rem, 2.4vw, 1.15rem);
  color: var(--muted);
  letter-spacing: 0.04em;
  margin-bottom: 56px;
  max-width: 480px;
  opacity: 0;
  animation: rise 0.7s 0.5s cubic-bezier(.22,1,.36,1) forwards;
}
.slogan em { font-style: normal; color: var(--accent); font-weight: 500; }

/* ── CARD ── */
.card {
  width: 100%;
  max-width: 500px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 28px 32px;
  margin-bottom: 40px;
  text-align: left;
  position: relative;
  overflow: hidden;
  opacity: 0;
  animation: rise 0.8s 0.65s cubic-bezier(.22,1,.36,1) forwards;
  transition: border-color 0.4s, box-shadow 0.4s;
}
.card::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(74,240,255,0.04) 0%, rgba(123,92,255,0.04) 100%);
  opacity: 0; transition: opacity 0.4s; pointer-events: none;
}
.card:hover { border-color: var(--border-h); box-shadow: var(--glow-a); }
.card:hover::after { opacity: 1; }

.card-header {
  display: flex; align-items: center; gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 18px;
  border-bottom: 1px solid var(--border);
}
.card-icon {
  width: 38px; height: 38px; border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, rgba(74,240,255,0.12), rgba(123,92,255,0.12));
  border: 1px solid rgba(74,240,255,0.18);
  font-size: 1.05rem; flex-shrink: 0;
}
.card-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700; font-size: 0.9rem;
  letter-spacing: 0.06em; color: var(--text); text-transform: uppercase;
}
.card-sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.68rem; color: var(--muted); margin-top: 2px;
}

.guarantees { display: flex; flex-direction: column; gap: 8px; }

.guarantee-item {
  display: flex; align-items: center; gap: 14px;
  padding: 13px 16px;
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 8px;
  transition: background 0.3s, border-color 0.3s, transform 0.25s;
  cursor: default;
}
.guarantee-item:hover {
  background: rgba(255,255,255,0.045);
  border-color: rgba(74,240,255,0.15);
  transform: translateX(5px);
}
.gi-badge {
  width: 26px; height: 26px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,68,102,0.09);
  border: 1px solid rgba(255,68,102,0.2);
  border-radius: 6px;
  font-size: 0.75rem;
  color: var(--red);
  font-family: 'JetBrains Mono', monospace;
  font-weight: 500;
}
.gi-text {
  font-family: 'Syne', sans-serif;
  font-size: 0.88rem; font-weight: 600;
  color: var(--text); letter-spacing: 0.02em;
}
.gi-text strong { color: var(--accent); font-weight: 700; }
.gi-check {
  margin-left: auto;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.62rem; color: #3dff99;
  letter-spacing: 0.06em; opacity: 0.65;
  flex-shrink: 0;
}

/* ── CTA ── */
.cta-group {
  display: flex; flex-direction: column; align-items: center; gap: 14px;
  opacity: 0;
  animation: rise 0.8s 0.8s cubic-bezier(.22,1,.36,1) forwards;
}

.btn-cta {
  position: relative;
  display: inline-flex; align-items: center; justify-content: center; gap: 10px;
  padding: 0 44px;
  height: 56px;
  font-family: 'Syne', sans-serif;
  font-weight: 700; font-size: 0.92rem;
  letter-spacing: 0.12em; text-transform: uppercase;
  text-decoration: none;
  color: #07080f;
  background: linear-gradient(135deg, var(--accent) 0%, #6af5c8 100%);
  border-radius: 10px; border: none; cursor: pointer;
  overflow: hidden;
  box-shadow: 0 0 0 1px rgba(74,240,255,0.3), 0 8px 32px rgba(74,240,255,0.25), 0 2px 8px rgba(0,0,0,0.4);
  transition: transform 0.25s cubic-bezier(.22,1,.36,1), box-shadow 0.25s ease;
}
.btn-cta::before {
  content: '';
  position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  animation: shine 3s 2s ease-in-out infinite;
}
@keyframes shine { 0%{left:-100%;opacity:1} 50%{left:150%;opacity:1} 100%{left:150%;opacity:0} }
.btn-cta::after {
  content: ''; position: absolute; inset: 1px; border-radius: 9px;
  background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 60%);
  pointer-events: none;
}
.btn-cta:hover {
  transform: translateY(-3px) scale(1.025);
  box-shadow: 0 0 0 1px rgba(74,240,255,0.5), 0 16px 48px rgba(74,240,255,0.35), 0 4px 16px rgba(0,0,0,0.4);
}
.btn-cta:active { transform: translateY(-1px) scale(1.01); }

.btn-arrow {
  width: 22px; height: 22px;
  background: rgba(0,0,0,0.15);
  border-radius: 5px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem;
  transition: transform 0.3s;
}
.btn-cta:hover .btn-arrow { transform: translateX(4px); }

.cta-note {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.69rem; color: var(--faint);
  letter-spacing: 0.05em;
  display: flex; align-items: center; gap: 10px;
}
.cta-note::before, .cta-note::after { content: ''; width: 24px; height: 1px; background: var(--faint); }

/* ── STATS ── */
.stats-section {
  position: relative; z-index: 10;
  padding: 0 24px 80px;
  display: flex; justify-content: center;
}
.stats {
  width: 100%; max-width: 500px;
  display: flex;
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
  opacity: 0;
  animation: rise 0.8s 1s cubic-bezier(.22,1,.36,1) forwards;
}
.stat {
  flex: 1; padding: 22px 16px; text-align: center;
  border-right: 1px solid var(--border);
  background: var(--surface);
  transition: background 0.3s;
}
.stat:last-child { border-right: none; }
.stat:hover { background: rgba(74,240,255,0.04); }
.stat-val {
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: 1.6rem; color: var(--accent); line-height: 1;
  margin-bottom: 5px; text-shadow: 0 0 20px rgba(74,240,255,0.4);
}
.stat-lbl {
  font-size: 0.68rem; color: var(--muted);
  letter-spacing: 0.07em; text-transform: uppercase; font-weight: 500;
}

/* ── FOOTER ── */
footer {
  position: relative; z-index: 10;
  text-align: center; padding: 32px 24px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.68rem; color: var(--faint);
  letter-spacing: 0.08em;
  border-top: 1px solid var(--border);
}
footer span { color: rgba(74,240,255,0.4); }

/* ── SCROLL HINT ── */
.scroll-hint {
  position: absolute; bottom: 28px; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  opacity: 0.28;
  animation: float 2.5s ease-in-out infinite;
}
.scroll-hint-line { width: 1px; height: 36px; background: linear-gradient(180deg, transparent, var(--accent)); }
@keyframes float { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }

/* ── SHARED ── */
@keyframes rise {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── RESPONSIVE ── */
@media (max-width: 600px) {
  nav { padding: 0 20px; }
  .nav-badge { display: none; }
  .hero { padding: 90px 16px 50px; }
  .card { padding: 22px 18px; }
  .btn-cta { height: 52px; padding: 0 28px; font-size: 0.85rem; }
}
@media (max-width: 400px) {
  .stats { flex-direction: column; }
  .stat { border-right: none; border-bottom: 1px solid var(--border); }
  .stat:last-child { border-bottom: none; }
}

/* ══════════════════════════════════════
   LOADING INTRO
══════════════════════════════════════ */
#loader {
  position: fixed; inset: 0; z-index: 9999;
  background: #020309;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  overflow: hidden;
  transition: opacity 0.7s ease, transform 0.7s ease;
}
#loader.hide {
  opacity: 0;
  pointer-events: none;
  transform: scale(1.04);
}

/* Matrix canvas behind everything */
#matrix-canvas {
  position: absolute; inset: 0;
  opacity: 0.18;
}

/* Horizontal scan sweep */
#loader::after {
  content: '';
  position: absolute; inset: 0; pointer-events: none;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 3px,
    rgba(0,0,0,0.08) 3px,
    rgba(0,0,0,0.08) 4px
  );
  z-index: 2;
  animation: scanY 6s linear infinite;
}
@keyframes scanY {
  0%   { background-position: 0 0; }
  100% { background-position: 0 400px; }
}

/* Glitch overlay flash */
.loader-glitch-flash {
  position: absolute; inset: 0; z-index: 3; pointer-events: none;
  background: rgba(74,240,255,0.03);
  animation: flashLoop 0.2s steps(1) infinite;
}
@keyframes flashLoop {
  0%,100%{ opacity:0 } 50%{ opacity:1 }
}

/* ── CORNER BRACKETS ── */
.ld-corner {
  position: absolute; width: 44px; height: 44px; z-index: 5;
}
.ld-corner::before, .ld-corner::after {
  content: ''; position: absolute; background: var(--accent);
  box-shadow: 0 0 10px var(--accent), 0 0 20px rgba(74,240,255,0.4);
}
.ld-corner::before { width: 100%; height: 2px; top: 0; left: 0; }
.ld-corner::after  { width: 2px; height: 100%; top: 0; left: 0; }
.ld-corner.tl { top: 24px; left: 24px; }
.ld-corner.tr { top: 24px; right: 24px; transform: scaleX(-1); }
.ld-corner.bl { bottom: 24px; left: 24px; transform: scaleY(-1); }
.ld-corner.br { bottom: 24px; right: 24px; transform: scale(-1); }

/* ── LOADER CONTENT ── */
.ld-inner {
  position: relative; z-index: 10;
  display: flex; flex-direction: column; align-items: center;
  width: min(600px, 90vw);
  gap: 0;
}

/* Logo at top */
.ld-logo {
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: clamp(2rem, 6vw, 3.2rem);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  background: linear-gradient(135deg, #fff 20%, var(--accent) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  filter: drop-shadow(0 0 24px rgba(74,240,255,0.5));
  margin-bottom: 6px;
  animation: ld-logoIn 0.6s cubic-bezier(.22,1,.36,1) both;
  position: relative;
}
.ld-logo::before, .ld-logo::after {
  content: 'NOOB SCRIPT';
  position: absolute; inset: 0;
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: inherit; letter-spacing: inherit;
  pointer-events: none;
}
.ld-logo::before {
  background: linear-gradient(135deg,var(--red),#ff8800);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation: ld-glA 3s 0.8s infinite;
  clip-path: polygon(0 20%,100% 20%,100% 45%,0 45%);
}
.ld-logo::after {
  background: linear-gradient(135deg,var(--accent2),var(--accent));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation: ld-glB 3s 0.8s infinite;
  clip-path: polygon(0 60%,100% 60%,100% 78%,0 78%);
}
@keyframes ld-glA {
  0%,85%,100%{opacity:0;transform:none}
  87%{opacity:0.9;transform:translate(-6px,0)}
  90%{opacity:0;transform:translate(4px,0)}
}
@keyframes ld-glB {
  0%,82%,100%{opacity:0;transform:none}
  84%{opacity:0.7;transform:translate(5px,0)}
  88%{opacity:0;transform:none}
}
@keyframes ld-logoIn {
  from{opacity:0;transform:translateY(-16px)scale(0.95)}
  to{opacity:1;transform:none}
}

.ld-tagline {
  font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
  letter-spacing: 0.2em; color: rgba(74,240,255,0.55);
  text-transform: uppercase; margin-bottom: 36px;
  animation: ld-logoIn 0.6s 0.15s both;
}

/* ── TERMINAL BOX ── */
.ld-terminal {
  width: 100%;
  background: rgba(4,6,14,0.85);
  border: 1px solid rgba(74,240,255,0.14);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 0 0 1px rgba(74,240,255,0.05), 0 20px 60px rgba(0,0,0,0.6), inset 0 1px 0 rgba(74,240,255,0.08);
  animation: ld-logoIn 0.5s 0.3s both;
  margin-bottom: 28px;
}

.ld-terminal-bar {
  display: flex; align-items: center; gap: 7px;
  padding: 10px 16px;
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.ld-dot {
  width: 10px; height: 10px; border-radius: 50%;
}
.ld-dot:nth-child(1){background:#ff5f57;box-shadow:0 0 6px #ff5f57}
.ld-dot:nth-child(2){background:#febc2e;box-shadow:0 0 6px #febc2e}
.ld-dot:nth-child(3){background:#28c840;box-shadow:0 0 6px #28c840}
.ld-terminal-title {
  margin-left: auto; margin-right: auto;
  font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
  color: rgba(255,255,255,0.2); letter-spacing: 0.06em;
  transform: translateX(-15px);
}

.ld-terminal-body {
  padding: 18px 20px 20px;
  min-height: 160px;
  font-family: 'JetBrains Mono', monospace;
  font-size: clamp(0.7rem, 1.8vw, 0.8rem);
  line-height: 1.85;
  color: rgba(255,255,255,0.7);
}
.ld-line { display: block; white-space: pre; }
.ld-line.cmd::before { content: '❯  '; color: var(--accent); }
.ld-line.ok  { color: #3dff99; }
.ld-line.ok::before  { content: '✔  '; }
.ld-line.err { color: var(--red); }
.ld-line.dim { color: rgba(255,255,255,0.25); }
.ld-line.hi  { color: var(--accent); }

.ld-cursor {
  display: inline-block; width: 8px; height: 1em;
  background: var(--accent); vertical-align: middle;
  box-shadow: 0 0 8px var(--accent);
  animation: blink 0.75s steps(1) infinite;
  margin-left: 2px;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

/* ── PROGRESS ── */
.ld-progress-wrap {
  width: 100%; display: flex; flex-direction: column; gap: 10px;
  animation: ld-logoIn 0.5s 0.5s both;
}
.ld-progress-row {
  display: flex; align-items: center; justify-content: space-between;
  font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
  color: var(--muted); letter-spacing: 0.06em;
}
.ld-pct {
  color: var(--accent); font-weight: 500;
  text-shadow: 0 0 10px rgba(74,240,255,0.5);
  min-width: 38px; text-align: right;
}
.ld-bar-track {
  width: 100%; height: 3px;
  background: rgba(255,255,255,0.05);
  border-radius: 100px;
  overflow: hidden;
  position: relative;
}
.ld-bar-fill {
  height: 100%; width: 0%; border-radius: 100px;
  background: linear-gradient(90deg, var(--accent2), var(--accent));
  box-shadow: 0 0 12px rgba(74,240,255,0.6);
  transition: width 0.12s ease;
  position: relative;
}
.ld-bar-fill::after {
  content: '';
  position: absolute; top: 0; right: 0;
  width: 40px; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6));
  filter: blur(2px);
}

/* ── STATUS CHIPS ── */
.ld-chips {
  display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;
  margin-top: 24px;
  animation: ld-logoIn 0.5s 0.6s both;
}
.ld-chip {
  font-family: 'JetBrains Mono', monospace; font-size: 0.62rem;
  letter-spacing: 0.08em; padding: 4px 10px; border-radius: 100px;
  border: 1px solid rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.25);
  transition: all 0.4s;
}
.ld-chip.active {
  border-color: rgba(74,240,255,0.3);
  color: var(--accent);
  background: rgba(74,240,255,0.06);
  box-shadow: 0 0 10px rgba(74,240,255,0.1);
}
.ld-chip.done {
  border-color: rgba(61,255,153,0.25);
  color: #3dff99;
  background: rgba(61,255,153,0.05);
}
</style>
</head>
