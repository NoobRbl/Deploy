<script>
// ══ LOADING INTRO ENGINE ══
(function() {
  // ── Matrix rain ──
  const mc = document.getElementById('matrix-canvas');
  const mx = mc.getContext('2d');
  mc.width = innerWidth; mc.height = innerHeight;
  window.addEventListener('resize', () => { mc.width=innerWidth; mc.height=innerHeight; });
  const cols = Math.floor(mc.width / 18);
  const drops = Array(cols).fill(1);
  const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン01アイウエABCDEFGHIJKLMNOPQ0110'.split('');
  function drawMatrix() {
    mx.fillStyle = 'rgba(2,3,9,0.18)';
    mx.fillRect(0, 0, mc.width, mc.height);
    chars.forEach && drops.forEach((y, i) => {
      const ch = chars[Math.floor(Math.random()*chars.length)];
      const bright = Math.random() > 0.94;
      mx.fillStyle = bright ? '#ffffff' : (Math.random()>0.5?'#4af0ff':'#7b5cff');
      mx.font = `${bright?'bold ':''}14px JetBrains Mono, monospace`;
      mx.globalAlpha = bright ? 0.9 : (0.15 + Math.random()*0.35);
      mx.fillText(ch, i*18, y*18);
      mx.globalAlpha = 1;
      if (y*18 > mc.height && Math.random() > 0.97) drops[i] = 0;
      drops[i]++;
    });
  }
  const matrixInterval = setInterval(drawMatrix, 50);

  // ── Terminal typing engine ──
  const term = document.getElementById('ld-term');
  const cursor = document.getElementById('ld-cursor');
  const fillEl = document.getElementById('ld-fill');
  const pctEl  = document.getElementById('ld-pct');
  const statEl = document.getElementById('ld-status-txt');

  const SEQ = [
    { type: 'dim',  text: '# NOOB SCRIPT BOOT SEQUENCE v2.5.0',           delay: 0   },
    { type: 'dim',  text: '# ─────────────────────────────────────────', delay: 80  },
    { type: 'cmd',  text: 'sudo ./init_kernel --mode=stealth',              delay: 200, chip:0, pct:8,  status:'Loading kernel...' },
    { type: 'ok',   text: 'Kernel loaded [4.19.0-ns-amd64]',               delay: 520 },
    { type: 'cmd',  text: 'load_modules --all --bypass-detection',          delay: 180, chip:1, pct:22, status:'Nạp modules...' },
    { type: 'ok',   text: 'Modules OK  ─  inject.so, hook.so, mem.so',     delay: 600 },
    { type: 'cmd',  text: 'crypto_init --keygen RSA-4096',                 delay: 200, chip:2, pct:40, status:'Tạo khóa mã hoá...' },
    { type: 'dim',  text: '  Generating entropy pool... ████████ done',    delay: 300 },
    { type: 'ok',   text: 'Crypto layer initialized  [AES-256-GCM]',        delay: 500 },
    { type: 'cmd',  text: 'connect --server ns-core.internal --tls',        delay: 200, chip:3, pct:60, status:'Kết nối server...' },
    { type: 'dim',  text: '  Handshake... TLSv1.3 ✔   Latency: 4ms',      delay: 400 },
    { type: 'ok',   text: 'Connection established  [SECURE]',               delay: 300 },
    { type: 'cmd',  text: 'fetch_scripts --auth=premium --decrypt',        delay: 180, chip:4, pct:78, status:'Tải script...' },
    { type: 'dim',  text: '  Downloading payload [███████████] 100%',      delay: 500 },
    { type: 'ok',   text: 'All scripts verified  [SHA-256 MATCH]',          delay: 300 },
    { type: 'cmd',  text: 'render_ui --theme=cyberpunk --fps=120',          delay: 180, chip:5, pct:92, status:'Render giao diện...' },
    { type: 'ok',   text: 'UI ready',                                       delay: 380 },
    { type: 'hi',   text: '★  NOOB SCRIPT — SYSTEM READY  ★',             delay: 200, pct:100, status:'Hoàn tất!' },
  ];

  let lineIndex = 0;
  let currentPct = 0;
  let animating = false;

  function animatePct(target, cb) {
    if (animating) { fillEl.style.width=target+'%'; pctEl.textContent=target+'%'; currentPct=target; cb&&cb(); return; }
    animating = true;
    const start = currentPct, diff = target - start;
    const dur = Math.abs(diff) * 12;
    let s = null;
    const step = ts => {
      if (!s) s = ts;
      const p = Math.min((ts-s)/dur, 1);
      const v = Math.round(start + diff * p);
      fillEl.style.width = v+'%';
      pctEl.textContent  = v+'%';
      if (p < 1) { requestAnimationFrame(step); }
      else { currentPct=target; animating=false; cb&&cb(); }
    };
    requestAnimationFrame(step);
  }

  function appendLine(cls, text) {
    const el = document.createElement('span');
    el.className = 'ld-line ' + cls;
    el.textContent = text;
    term.insertBefore(el, cursor);
    term.scrollTop = term.scrollHeight;
  }

  function typeCmd(text, cb) {
    // Move cursor to end, type characters one by one
    const el = document.createElement('span');
    el.className = 'ld-line cmd';
    el.textContent = '';
    term.insertBefore(el, cursor);
    term.scrollTop = term.scrollHeight;
    let i = 0;
    const iv = setInterval(() => {
      el.textContent += text[i++];
      term.scrollTop = term.scrollHeight;
      if (i >= text.length) { clearInterval(iv); setTimeout(cb, 80); }
    }, 28 + Math.random()*18);
  }

  function activateChip(idx) {
    // Mark previous chips as done
    for (let i=0; i<idx; i++) {
      const c = document.getElementById('chip-'+i);
      if (c) { c.classList.remove('active'); c.classList.add('done'); }
    }
    const c = document.getElementById('chip-'+idx);
    if (c) c.classList.add('active');
  }

  function runStep() {
    if (lineIndex >= SEQ.length) {
      // Done — dismiss loader
      setTimeout(() => {
        clearInterval(matrixInterval);
        const loader = document.getElementById('loader');
        loader.classList.add('hide');
        // Mark all chips done
        for (let i=0; i<6; i++) {
          const c = document.getElementById('chip-'+i);
          if(c){c.classList.remove('active');c.classList.add('done');}
        }
        setTimeout(() => { loader.style.display='none'; }, 800);
      }, 600);
      return;
    }

    const s = SEQ[lineIndex++];

    setTimeout(() => {
      // Update chip + progress + status text if defined
      if (s.chip !== undefined) activateChip(s.chip);
      if (s.status) statEl.textContent = s.status;

      const next = () => {
        if (s.pct !== undefined) {
          animatePct(s.pct, runStep);
        } else {
          runStep();
        }
      };

      if (s.type === 'cmd') {
        typeCmd(s.text, () => { next(); });
      } else {
        appendLine(s.type, s.text);
        next();
      }
    }, s.delay || 0);
  }

  // Start after fonts load
  setTimeout(runStep, 400);
})();

// Star field
(function() {
  const cv = document.getElementById('stars');
  const cx = cv.getContext('2d');
  let W, H, stars;
  const resize = () => { W = cv.width = innerWidth; H = cv.height = innerHeight; initStars(); };
  const rand = (a,b) => a + Math.random()*(b-a);
  const initStars = () => {
    stars = Array.from({length:180}, () => ({
      x: rand(0,W), y: rand(0,H),
      r: rand(0.2,1.4), alpha: rand(0.05,0.5),
      speed: rand(0.003,0.01), phase: rand(0,Math.PI*2),
      color: Math.random()>0.7?'74,240,255':Math.random()>0.5?'123,92,255':'255,255,255'
    }));
  };
  let t = 0;
  const draw = () => {
    cx.clearRect(0,0,W,H);
    t += 0.016;
    stars.forEach(s => {
      const a = s.alpha*(0.4+0.6*Math.sin(t*s.speed*60+s.phase));
      cx.save(); cx.globalAlpha=a;
      cx.fillStyle=`rgb(${s.color})`;
      if(s.r>0.8){cx.shadowColor=`rgb(${s.color})`;cx.shadowBlur=6;}
      cx.beginPath(); cx.arc(s.x,s.y,s.r,0,Math.PI*2); cx.fill(); cx.restore();
    });
    requestAnimationFrame(draw);
  };
  window.addEventListener('resize', resize);
  resize(); draw();
})();

// Magnetic button
(function() {
  const btn = document.querySelector('.btn-cta');
  if(!btn) return;
  btn.addEventListener('mousemove', e => {
    const r = btn.getBoundingClientRect();
    const x = (e.clientX-r.left-r.width/2)/(r.width/2);
    const y = (e.clientY-r.top-r.height/2)/(r.height/2);
    btn.style.transform = `translateY(-3px) scale(1.025) translate(${x*6}px,${y*3}px)`;
  });
  btn.addEventListener('mouseleave', () => { btn.style.transform=''; });
})();

// Count-up on scroll
(function() {
  const items = document.querySelectorAll('.stat-val');
  const ease = t => t<.5?2*t*t:-1+(4-2*t)*t;
  const run = (el) => {
    const end = +el.dataset.end, suf = el.dataset.suffix||'', dur = 1300;
    let start = null;
    const step = ts => {
      if(!start) start=ts;
      const p = Math.min((ts-start)/dur,1);
      el.textContent = Math.round(ease(p)*end)+suf;
      if(p<1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting){ items.forEach(run); obs.disconnect(); }});
  },{threshold:0.3});
  const sec = document.querySelector('.stats');
  if(sec) obs.observe(sec);
})();
</script>
